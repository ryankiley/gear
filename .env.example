# Copy to .env and fill in. All optional for local dev — with none set, the app
# runs fully locally (PGlite database + in-memory rate limiting).

# Postgres. Set this for production (Neon). When unset, the app uses a local
# PGlite database instead (see PGLITE_DIR).
DATABASE_URL=

# Where the local PGlite database lives (dev only; ignored when DATABASE_URL is set).
PGLITE_DIR=.data/pglite

# Upstash Redis REST — the shared per-IP rate-limit store in production.
# When unset, rate limiting falls back to an in-memory store (fine for dev).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Token gating the admin-only moderation endpoints (catalog revert, list restore).
# Requests without a matching x-admin-token header get a 404. Leave unset to
# disable those routes entirely.
GEAR_ADMIN_TOKEN=
